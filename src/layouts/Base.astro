---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description: string;
  /** Absolute or root-relative OG image path. Defaults to the branded card. */
  ogImage?: string;
}
const { title, description, ogImage = '/og.png' } = Astro.props;

// Absolute URLs for canonical + social tags. Astro.site is the production
// origin (see astro.config.mjs); when it is unset (should not happen) these
// fall back to relative values rather than throwing.
//
// With build.format: 'file', Astro.url.pathname is the output file
// (/about.html, /index.html). Normalize to the served, slash-free URL so the
// canonical and og:url match how the page is actually reached (/about, /).
const cleanPath =
  Astro.url.pathname.replace(/index\.html$/, '').replace(/\.html$/, '') || '/';
const canonical = Astro.site
  ? new URL(cleanPath, Astro.site).href
  : cleanPath;
const ogImageUrl = Astro.site ? new URL(ogImage, Astro.site).href : ogImage;
const siteName = 'Stewardmark';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {/* Open Graph */}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Stewardmark — Building businesses and the people who run them." />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
  </body>
</html>
