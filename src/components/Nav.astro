---
import { getEntry } from 'astro:content';
import Logo from './Logo.astro';

const site = (await getEntry('site', 'site'))!.data;
// Services jumps to the home-page section from any page; Contact is its own
// route (contactHref). The header is identical site-wide.
---

<header class="nav band">
  <div class="container nav__inner">
    <a href="/" class="nav__brand" aria-label={`${site.name} home`}>
      <Logo size={36} typeSize={34} />
    </a>
    <nav class="nav__links" aria-label="Primary">
      <a href="/#services" class="nav__link">{site.nav.services}</a>
      <a href="/about" class="nav__link">{site.nav.about}</a>
      <a href={site.contactHref} class="nav__link nav__cta">{site.nav.contact}</a>
    </nav>
  </div>
</header>

<style>
  .nav__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding-block: 22px;
    border-bottom: 1px solid rgba(233, 236, 239, 0.12);
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
  }
  .nav__links {
    display: flex;
    gap: 26px;
    align-items: center;
    flex-wrap: wrap;
  }
  .nav__link {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-mist);
  }
  .nav__link:hover {
    color: var(--color-white);
  }
  .nav__cta {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--color-white);
    background: var(--color-accent);
    padding: 9px 18px;
    border-radius: var(--radius-control);
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .nav__cta:hover {
    background: var(--color-accent-hover);
    color: var(--color-white);
    transform: scale(1.02);
  }

  /* On narrow screens the links no longer fit beside the wordmark. Stack the
     header: brand on top, then the links in a tidy left-aligned column,
     indented to sit under the wordmark, with even vertical spacing. */
  @media (max-width: 640px) {
    .nav__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 18px;
    }
    .nav__links {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
      flex-wrap: nowrap;
      /* Indent to align under the wordmark: logo mark width + its 10px gap. */
      padding-left: calc(var(--logo-nav-mark) + 10px);
    }
    /* On mobile, Contact drops the button chrome and becomes a plain text
       link, keeping the button's Kiln Orange as its font color. */
    .nav__cta {
      background: none;
      padding: 0;
      border-radius: 0;
      font-size: 14px;
      color: var(--color-accent);
    }
    .nav__cta:hover {
      background: none;
      transform: none;
      color: var(--color-white);
    }
  }
</style>
